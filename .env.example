# ──────────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ──────────────────────────────────────────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────────────────────────────────────────
# Generate a strong random secret:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"

# Full public URL of your deployment (no trailing slash)
# Development:   http://localhost:3000
# Production:    https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────────────────────
# Seed (optional — used by `prisma/seed.ts`)
# ──────────────────────────────────────────────────────────────────────────────
# Override defaults used when running `npx prisma db seed`
# Defaults: admin@vedpragya.local / Admin123!  and  ceo@acme.local / Client123!
SEED_ADMIN_EMAIL="admin@yourcompany.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_USER_EMAIL="ceo@yourclient.com"
SEED_USER_PASSWORD="ChangeMe123!"
